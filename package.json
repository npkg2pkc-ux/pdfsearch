{
  "name": "pdf-tag-search",
  "version": "1.0.0",
  "description": "Aplikasi pencarian PDF berdasarkan tag/komentar/anotasi",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "sqlite3": "^5.1.7",
    "cors": "^2.8.5",
    "pdfjs-dist": "^4.0.379",
    "@aws-sdk/client-s3": "^3.500.0",
    "pg": "^8.11.0",
    "formidable": "^2.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
  ,
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "worker": "node worker/processor.js",
    "electron": "electron .",
    "dist": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.example.pdfsearch",
    "productName": "PDF Tag Search",
    "win": {
      "target": ["nsis"]
    },
    "files": [
      "**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,README,readme.md,test}" 
    ],
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^26.0.0",
    "electron-builder": "^24.0.0",
    "node-fetch": "^3.4.0"
  }
}
